# Cloudflare Pages headers. Expo copies public/ into dist verbatim.
#
# The HTML must always revalidate: after every deploy the page references new
# hashed bundles, and a browser-cached HTML shell pins users to the previous
# build ("I can't see the changes"). The hashed assets themselves are
# content-addressed and safely immutable.

/*
  Cache-Control: no-cache

/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
