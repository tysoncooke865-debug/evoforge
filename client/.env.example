# Copy to .env.local (gitignored) and fill in from the Supabase dashboard.
# These are EXPO_PUBLIC_: they compile into the client bundle. That is what the
# publishable key is for -- RLS is the guard, not key secrecy. The SECRET key
# and OPENAI_API_KEY must never appear here or in any EXPO_PUBLIC_ var; AI calls
# go through Supabase Edge Functions (MIGRATION_PLAN "AI via Edge Functions").
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_...
