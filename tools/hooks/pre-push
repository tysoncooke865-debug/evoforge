#!/usr/bin/env bash
#
# EvoForge pre-push: run the no-database verification suite before anything
# leaves this machine.
#
# ###########################################################################
# #  THIS IS CONVENIENCE, NOT ENFORCEMENT.                                  #
# #                                                                         #
# #  It only runs where someone remembered:                                 #
# #      git config core.hooksPath tools/hooks                              #
# #  An uninstalled hook cannot verify its own installation, and a GUI git  #
# #  client may not invoke it at all. Do not build machinery to prove it is #
# #  installed -- that is what .github/workflows/verify.yml is for.         #
# #                                                                         #
# #  CI is the gate. This just tells you sooner.                            #
# ###########################################################################
#
# Install once:
#     git config core.hooksPath tools/hooks
#
# Escape hatch, for when you know what you are doing:
#     git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PYTHON="${PYTHON:-python}"

# STREAMLIT RETIRED (Tyson, 2026-07-16): the Python suite guards the
# Streamlit app, which no longer ships. Skip it when the outgoing commits
# touch nothing outside client/ and docs — the client has its own loop
# (HANDOVER §5) and CI. Any Python-side change still runs the full suite.
OUTGOING="$(git diff --name-only @{push}..HEAD 2>/dev/null || git diff --name-only origin/$(git rev-parse --abbrev-ref HEAD)..HEAD 2>/dev/null || true)"
if [ -n "$OUTGOING" ] && ! printf '%s\n' "$OUTGOING" | grep -qvE '^(client/|[^/]+\.md$)'; then
    echo ""
    echo "pre-push: client/docs-only push — the Streamlit suite is retired for these paths. Pushing."
    echo ""
    exit 0
fi

# THE GREAT LEANING (2026-07-19): the Streamlit verify suite is deleted.
# What survives on the Python side is the goldens contract -- domain/*.py +
# config/constants.py feeding tools/gen_fixtures.py --check. A push touching
# any non-client path runs that single guard; client.yml remains the gate.
echo ""
printf '  %-28s ' "gen_fixtures --check"
if "$PYTHON" tools/gen_fixtures.py --check >/dev/null 2>&1; then
    echo "PASS"
    echo ""
    echo "pre-push: goldens contract green. Pushing."
    echo ""
    exit 0
fi

echo "FAIL"
echo ""
echo "=============================================================="
echo " PUSH BLOCKED: the goldens contract check failed."
echo "=============================================================="
echo " Run it directly to see why:"
echo "     python tools/gen_fixtures.py --check"
echo ""
echo " Escape hatch: git push --no-verify"
echo "=============================================================="
exit 1
